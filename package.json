{
  "name": "@bopstack/oxfmt",
  "version": "0.1.0",
  "private": false,
  "description": "Shared oxfmt (formatter) configuration for Bopstack projects",
  "license": "MIT",
  "files": [
    "src/",
    "oxfmtrc.json"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
